---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<Layout title={project.data.title} description={`${project.data.category} — ${project.data.year}`}>
  <div class="relative w-full min-h-screen flex flex-col md:flex-row bg-white overflow-x-hidden">
    
    <!-- Left: Image Gallery -->
    <div 
      id="gallery-container"
      class="w-full md:w-2/3 h-[60vh] md:h-screen overflow-y-auto hide-scrollbar pt-24 pb-12 px-4 md:px-12 flex flex-col gap-6 md:gap-10 transition-all duration-500 ease-in-out border-r border-neutral-50"
    >
      {project.data.images.map((img, idx) => (
        <img 
          src={img} 
          alt={`${project.data.title} - Image ${idx + 1}`} 
          class="w-full object-cover aspect-[16/10] md:aspect-auto hover:opacity-95 transition-opacity duration-300 bg-neutral-50"
          loading={idx === 0 ? "eager" : "lazy"}
        />
      ))}
    </div>

    <!-- Right: Text Panel -->
    <div 
      id="text-panel"
      class="fixed bottom-0 left-0 w-full h-[70vh] md:h-screen md:w-1/3 md:top-0 md:right-0 md:left-auto bg-white/90 backdrop-blur-md border-t md:border-t-0 md:border-l border-neutral-100 z-40 flex flex-col pt-8 pb-12 px-6 md:pt-28 md:px-10 overflow-y-auto transition-transform duration-500 ease-in-out translate-y-full md:translate-y-0 md:translate-x-0 shadow-2xl md:shadow-none rounded-t-2xl md:rounded-none"
    >
      <!-- Close Button -->
      <button 
        id="close-btn"
        class="absolute top-6 right-6 md:top-8 md:right-8 text-neutral-400 hover:text-[#1A1A1A] transition-colors duration-300 p-2 cursor-pointer focus:outline-none"
        aria-label="Close details"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Meta Info -->
      <div class="mb-6">
        <span class="text-[10px] tracking-[0.25em] uppercase text-neutral-400 font-semibold block mb-2">
          {project.data.category} — {project.data.year}
        </span>
        <h1 class="text-2xl md:text-3xl font-light tracking-tight font-display text-neutral-900 leading-tight">
          {project.data.title}
        </h1>
      </div>

      <!-- Description / Content -->
      <div class="text-sm font-light text-neutral-600 leading-relaxed space-y-4 max-w-none">
        <Content />
      </div>

      <!-- Back Button -->
      <div class="mt-auto pt-12">
        <a 
          href="/projects" 
          class="inline-flex items-center gap-2 text-xs tracking-[0.15em] uppercase text-neutral-400 hover:text-[#1A1A1A] transition-colors duration-300"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          Back to Projects
        </a>
      </div>
    </div>

    <!-- Floating Info Button (Visible when panel is closed/minimized) -->
    <button 
      id="info-btn"
      class="fixed bottom-6 right-6 z-50 bg-[#1A1A1A] text-white hover:bg-neutral-800 px-5 py-3 text-[10px] tracking-[0.2em] uppercase transition-all duration-300 cursor-pointer shadow-lg opacity-0 pointer-events-none md:shadow-md"
    >
      Info
    </button>

  </div>
</Layout>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>

<script>
  const textPanel = document.getElementById('text-panel');
  const galleryContainer = document.getElementById('gallery-container');
  const closeBtn = document.getElementById('close-btn');
  const infoBtn = document.getElementById('info-btn');

  if (textPanel && galleryContainer && closeBtn && infoBtn) {
    // Check screen size
    const isMobile = () => window.innerWidth < 768;

    function initLayout() {
      if (isMobile()) {
        // Mobile initial state: Panel hidden (translate-y-full), Info visible
        textPanel.classList.add('translate-y-full');
        textPanel.classList.remove('translate-y-0', 'md:translate-x-0', 'md:translate-x-full');
        infoBtn.classList.remove('opacity-0', 'pointer-events-none');
        infoBtn.classList.add('opacity-100', 'pointer-events-auto');
        galleryContainer.classList.remove('md:w-2/3', 'md:w-full');
      } else {
        // Desktop initial state: Panel open (translate-x-0), Gallery 2/3 width, Info hidden
        textPanel.classList.remove('translate-y-full', 'translate-y-0', 'md:translate-x-full');
        textPanel.classList.add('md:translate-x-0');
        galleryContainer.classList.remove('md:w-full');
        galleryContainer.classList.add('md:w-2/3');
        infoBtn.classList.add('opacity-0', 'pointer-events-none');
        infoBtn.classList.remove('opacity-100', 'pointer-events-auto');
      }
    }

    // Run on init
    initLayout();
    window.addEventListener('resize', initLayout);

    // Click Close Button
    closeBtn.addEventListener('click', () => {
      if (isMobile()) {
        // Slide panel down
        textPanel.classList.add('translate-y-full');
        textPanel.classList.remove('translate-y-0');
      } else {
        // Slide panel right
        textPanel.classList.add('md:translate-x-full');
        textPanel.classList.remove('md:translate-x-0');
        // Expand gallery
        galleryContainer.classList.remove('md:w-2/3');
        galleryContainer.classList.add('md:w-full');
      }
      // Show Info button
      infoBtn.classList.remove('opacity-0', 'pointer-events-none');
      infoBtn.classList.add('opacity-100', 'pointer-events-auto');
    });

    // Click Info Button
    infoBtn.addEventListener('click', () => {
      if (isMobile()) {
        // Slide panel up
        textPanel.classList.remove('translate-y-full');
        textPanel.classList.add('translate-y-0');
      } else {
        // Slide panel left (show)
        textPanel.classList.remove('md:translate-x-full');
        textPanel.classList.add('md:translate-x-0');
        // Shrink gallery
        galleryContainer.classList.remove('md:w-full');
        galleryContainer.classList.add('md:w-2/3');
      }
      // Hide Info button
      infoBtn.classList.add('opacity-0', 'pointer-events-none');
      infoBtn.classList.remove('opacity-100', 'pointer-events-auto');
    });
  }
</script>
